# ── 三源实时数据（FIFA / Polymarket / 体彩，master 分支）──
# 无需 API 密钥。以下均为可选的非敏感质量配置。
FIFA_COMPETITION_ID=17
WORLD_CUP_TOURNAMENT_START=2026-06-11
WORLD_CUP_SCHEDULE_TIMEZONE=America/New_York
WORLD_CUP_OUTPUT_TIMEZONE=Asia/Shanghai
POLYMARKET_MIN_LIQUIDITY=10000
MARKET_PROBABILITY_SUM_MIN=0.90
MARKET_PROBABILITY_SUM_MAX=1.10
KICKOFF_TOLERANCE_MINUTES=15

# ── 外网辅盘（The Odds API，dev/jun-odds 分支）──
# 免费注册：https://the-odds-api.com
ODDS_API_KEY=

# 可选：默认体育类型与博彩公司区域
ODDS_SPORT=soccer_fifa_world_cup
ODDS_REGIONS=uk,eu,us
